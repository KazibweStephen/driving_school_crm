# Database
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=crm_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# JWT (generate a strong random secret, e.g. openssl rand -hex 32)
JWT_SECRET_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (JSON array of allowed origins)
CORS_ORIGINS=["https://your-domain.com","https://www.your-domain.com"]

# SMS (logging adapter by default)
SMS_PROVIDER=logging

# Receipt / app URLs
RECEIPT_BASE_URL=https://your-domain.com
APP_URL=https://your-domain.com

# App
APP_NAME=Driving School CRM
DEBUG=false
